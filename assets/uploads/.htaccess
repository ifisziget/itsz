Options -ExecCGI
RemoveHandler .php .php3 .php4 .php5 .php7 .php8 .phtml .phar .cgi .pl .py .rb .sh
RemoveType .php .php3 .php4 .php5 .php7 .php8 .phtml .phar

<FilesMatch "\.(php\d*|phtml|phar|cgi|pl|py|rb|sh)$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>
